generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  firstName             String?
  lastName              String?
  fullName              String?
  email                 String    @unique
  phone                 String?
  whatsappNumber        String?
  password              String
  role                  String    @default("client") // super_admin, admin, associate, client
  subRole               String?   // hr, recruiter, manager, etc.
  bio                   String?   @db.Text
  occupation            String?
  city                  String?
  country               String?
  profilePicture        String?   @db.Text
  status                String    @default("active")
  
  // New Fields from UI
  address               String?   @db.Text
  age                   Int?
  apiEmail              String?
  application           String?   // Could be a relation later
  associateAssigned     String?
  canWorkOnsite        Boolean?  @default(false)
  certifications        String?   @db.Text
  clientAssigned        String?
  coverLetter           String?   @db.Text
  createdBy             String?
  cvResume              String?   @db.Text
  department            String?
  dob                   DateTime?
  drivesLicense        Boolean?  @default(false)
  eligibleToWork        String?
  emergencyContactName  String?
  emergencyContactPhone String?
  employmentStatus      String?
  gender                String?
  jobLevel              String?
  jobTitle              String?
  linkedinUrl           String?   @db.Text
  memberSince           DateTime? @default(now())
  notes                 String?   @db.Text
  backgroundCheck       String?
  preferredIndustry     String?
  preferredLocation     String?
  preferredJobTitles    String?
  salaryMax             Decimal?  @db.Decimal(15, 2)
  salaryMin             Decimal?  @db.Decimal(15, 2)
  securityClearance     String?
  startDate             DateTime?
  stripeCustomerId      String?
  subscription          String?
  subscriptionStatus    String?
  socialNetworks        String?   @db.Text
  slug                  String?   @unique
  uniqueId              String?   @unique @default(uuid())

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
}
