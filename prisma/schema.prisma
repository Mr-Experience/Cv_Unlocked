generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String?
  lastName  String?
  email     String   @unique
  phone     String?
  password  String
  role      String   @default("client") // super_admin, admin, associate, client
  createdAt DateTime @default(now())
}
